{
    "name": "andreaskasper/phlibs",
    "type": "library",
    "description": "A lightweight PHP utility library: MySQL/PDO database wrappers, HTTP caching, web content caching, string helpers.",
    "keywords": ["php", "mysql", "mysqli", "pdo", "database", "cache", "utility"],
    "authors": [
        {
            "name": "Andreas Kasper",
            "email": "andreas.kasper@goo1.de"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "suggest": {
        "ext-mysqli": "Required for the SQL class",
        "ext-pdo": "Required for the DB class",
        "ext-mbstring": "Recommended for multibyte string support"
    },
    "autoload": {
        "psr-4": {
            "phlibs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "phlibs\\Test\\": "phpunit_test/"
        }
    },
    "license": "FreeFoodLicense"
}
